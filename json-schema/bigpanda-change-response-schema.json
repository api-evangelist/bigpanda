{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChangeResponse",
  "type": "object",
  "description": "Response after ingesting a change event.",
  "properties": {
    "_id": {
      "type": "string",
      "description": "Internal change ID.",
      "example": "chg-abc123"
    },
    "status": {
      "type": "string",
      "description": "Ingestion status.",
      "example": "ok"
    }
  }
}